---
import { profile } from '../data/profile';

const { name, lastUpdated } = profile;
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 px-6 py-8 dark:border-slate-700">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center gap-2 text-sm text-slate-500 dark:text-slate-400"
  >
    <p>&copy; {year} {name.en}</p>
    <p>Last updated: {lastUpdated}</p>
  </div>
</footer>
