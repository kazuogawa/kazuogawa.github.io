---
import { profile } from '../data/profile';
import SocialIcons from './SocialIcons';

const { name, title, tagline, photo, social } = profile;
---

<section id="hero" class="flex min-h-[calc(100vh-73px)] items-center justify-center px-6 py-20">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-12 md:flex-row md:gap-16">
    <div class="flex-shrink-0">
      <img
        src={photo}
        alt={`${name.ja}のプロフィール写真`}
        class="h-48 w-48 rounded-full object-cover shadow-lg ring-4 ring-white md:h-56 md:w-56 dark:ring-slate-800"
        width="224"
        height="224"
      />
    </div>
    <div class="text-center md:text-left">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl dark:text-white">
        {name.ja}
      </h1>
      <p class="mt-2 text-lg text-slate-500 dark:text-slate-400">
        {name.en}
      </p>
      <p class="mt-4 text-xl font-medium text-blue-600 dark:text-blue-400">
        {title}
      </p>
      <p class="mt-3 max-w-lg text-slate-600 dark:text-slate-300">
        {tagline}
      </p>
      <div class="mt-6 flex justify-center md:justify-start">
        <SocialIcons links={social} client:visible />
      </div>
    </div>
  </div>
</section>
