---
import type { ExperienceEntry } from '../types/profile';

interface Props {
  entry: ExperienceEntry;
}

const { entry } = Astro.props;
---

<div class:list={['relative pb-12 pl-8 last:pb-0', { 'opacity-80': entry.compact }]}>
  <!-- Timeline dot and line -->
  <div
    class:list={[
      'absolute left-0 top-1 rounded-full border-2 border-blue-600 dark:border-blue-400',
      entry.compact ? 'h-3 w-3 bg-transparent' : 'h-4 w-4 bg-blue-600 dark:bg-blue-400',
    ]}
  >
  </div>
  <div class="absolute left-[7px] top-5 h-full w-px bg-slate-200 last:hidden dark:bg-slate-700">
  </div>

  <!-- Content -->
  <div>
    <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
      <h3
        class:list={[
          'font-semibold text-slate-900 dark:text-white',
          entry.compact ? 'text-base' : 'text-xl',
        ]}
      >
        {entry.role}
      </h3>
      <span class="text-sm font-medium text-blue-600 dark:text-blue-400">
        {entry.period}
      </span>
    </div>
    <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">{entry.company}</p>

    {entry.tech && <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{entry.tech}</p>}

    <div class:list={['mt-4 space-y-4', { 'mt-2 space-y-2': entry.compact }]}>
      {
        entry.projects.map((project) => (
          <div>
            <h4 class="font-medium text-slate-800 dark:text-slate-200">
              {project.link ? (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline decoration-blue-600/30 underline-offset-2 transition-colors hover:text-blue-600 dark:decoration-blue-400/30 dark:hover:text-blue-400"
                >
                  {project.title}
                </a>
              ) : (
                project.title
              )}
            </h4>
            <ul class="mt-1 space-y-1">
              {project.details.map((detail) => (
                <li class="flex gap-2 text-sm text-slate-600 dark:text-slate-300">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-400 dark:bg-slate-500" />
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</div>
